[Unit]
Description=SX1303 LoRa Packet Forwarder
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=uhrkgc
WorkingDirectory=/home/uhrkgc/gateway/sx1302_hal_rpi5-master/packet_forwarder
ExecStart=/home/uhrkgc/gateway/sx1302_hal_rpi5-master/packet_forwarder/lora_pkt_fwd -c /home/uhrkgc/gateway/sx1302_hal_rpi5-master/packet_forwarder/test_conf.json
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
